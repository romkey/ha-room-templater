# Home Assistant connection (required)
HA_URL=http://homeassistant.local:8123
HA_TOKEN=

# Optional: prefix on template friendly names to avoid entity conflicts (default: canonical_)
# NAME_PREFIX=canonical_
# Set NAME_PREFIX= (empty) to omit a prefix

# Optional: comma-separated area names to skip
# EXCLUDE_AREAS=Garage,Outside

# Optional: where to write generated template sensor YAML (default: rooms_generated.yaml)
# OUTPUT_PATH=rooms_generated.yaml

# Optional: Lovelace dashboard YAML, one tab per room (default: rooms_dashboard.yaml)
# DASHBOARD_OUTPUT_PATH=rooms_dashboard.yaml
