{# Per-room sensor aggregation macros for Home Assistant.
   Install: <config>/custom_templates/room.jinja
   Reload: Developer tools → YAML → Reload template entities

   Exclude entities via label ignore_canonical.
   Exclude entity ids containing _canonical_ (generated template sensors in the same area).
   Pair each state macro with an available_* macro for template availability: templates.

   Note: macros render to text; entity lists are built with {% set %} + filters in each macro. #}

{% macro join_names(entity_ids) -%}
{%- set ns = namespace(names=[]) -%}
{%- for eid in entity_ids -%}
  {%- set ns.names = ns.names + [state_attr(eid, 'friendly_name') or eid] -%}
{%- endfor -%}
{{ ns.names | join(', ') }}
{%- endmacro %}

{# ---------- Unit conversion ---------- #}

{% macro convert_to_canonical(value, source_unit, canonical_unit) -%}
{{ value if ((source_unit or '') | lower) == ((canonical_unit or '') | lower) or ((source_unit or '') | lower) == '' else ((value - 32) * 5 / 9) if ((canonical_unit or '') | lower) in ['°c', 'c'] and ((source_unit or '') | lower) in ['°f', 'f'] else (value * 9 / 5 + 32) if ((canonical_unit or '') | lower) in ['°f', 'f'] and ((source_unit or '') | lower) in ['°c', 'c'] else (value * 1000) if ((canonical_unit or '') | lower) == 'w' and ((source_unit or '') | lower) == 'kw' else (value / 1000) if ((canonical_unit or '') | lower) == 'w' and ((source_unit or '') | lower) == 'mw' else (value / 1000) if ((canonical_unit or '') | lower) == 'kwh' and ((source_unit or '') | lower) == 'wh' else (value * 1000) if ((canonical_unit or '') | lower) == 'kwh' and ((source_unit or '') | lower) == 'mwh' else (value * 1000) if ((canonical_unit or '') | lower) == 'ppb' and ((source_unit or '') | lower) == 'ppm' else (value * 1000) if ((canonical_unit or '') | lower) == 'µg/m³' and ((source_unit or '') | lower) == 'mg/m³' else none }}
{%- endmacro %}

{# ---------- Availability ---------- #}

{% macro available_numeric_by_dc(area, dc, canonical_unit) -%}
{%- set ns = namespace(n=0) -%}
{%- for eid in area_entities(area) | select('is_state_attr', 'device_class', dc) | reject('search', '_canonical_') -%}
  {%- if eid not in label_entities('ignore_canonical') -%}
    {%- if states(eid) not in ['unavailable', 'unknown', ''] -%}
      {%- set val = states(eid) | float(none) -%}
      {%- if val is not none -%}
        {%- set src_unit = state_attr(eid, 'unit_of_measurement') -%}
        {%- set converted = convert_to_canonical(val, src_unit, canonical_unit) | float(none) -%}
        {%- if converted is not none -%}
          {%- set ns.n = ns.n + 1 -%}
        {%- endif -%}
      {%- endif -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}
{{ (ns.n > 0) }}
{%- endmacro %}

{% macro available_sources_by_dc(area, dc) -%}
{{ (area_entities(area)
    | select('is_state_attr', 'device_class', dc)
    | reject('search', '_canonical_')
    | reject('in', label_entities('ignore_canonical'))
    | list | length > 0) }}
{%- endmacro %}

