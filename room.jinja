{# ---------- Switches by name substring ---------- #}

{% macro any_switch_named(area, substr) -%}
{%- set ns = namespace(found=false) -%}
{%- for eid in area_entities(area) | select('search', '^switch[.]') | reject('search', '_canonical_') -%}
  {%- set name = (state_attr(eid, 'friendly_name') or eid) | lower -%}
  {%- if (substr | lower) in name and eid not in label_entities('ignore_canonical') and states(eid) == 'on' -%}
    {%- set ns.found = true -%}
  {%- endif -%}
{%- endfor -%}
{{ ns.found }}
{%- endmacro %}

{% macro all_switches_named(area, substr) -%}
{%- set ns = namespace(ids=[]) -%}
{%- for eid in area_entities(area) | select('search', '^switch[.]') | reject('search', '_canonical_') -%}
