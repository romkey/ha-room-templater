  {%- if (substr | lower) in name and eid not in label_entities('ignore_canonical') -%}
    {%- set ns.ids = ns.ids + [eid] -%}
  {%- endif -%}
{%- endfor -%}
{{ join_names(ns.ids) }}
{%- endmacro %}

